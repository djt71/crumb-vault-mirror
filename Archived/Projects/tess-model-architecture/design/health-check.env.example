# tess-health-check.sh credentials
# Copy to /Users/tess/.config/tess/health-check.env and fill in values.
# DO NOT commit the filled-in version to git.

ANTHROPIC_API_KEY=sk-ant-...
# Telegram credentials are read from Keychain (shared with x-feed-intel):
#   security find-generic-password -a x-feed-intel -s x-feed-intel.telegram-bot-token -w
#   security find-generic-password -a x-feed-intel -s x-feed-intel.telegram-chat-id -w
